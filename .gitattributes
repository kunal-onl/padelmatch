# Normalize line endings to LF in the repository, regardless of the
# contributor's OS or git core.autocrlf setting. This prevents phantom
# whole-file diffs (e.g. when editing on Windows) and keeps the repo
# consistent with the Linux-based Emergent environment.
* text=auto

# Explicit binary types — never apply EOL conversion or text diffing.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.tgz   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# Lockfiles: tracked as text, but suppress noisy diffs and merge churn.
yarn.lock         -diff
package-lock.json -diff
